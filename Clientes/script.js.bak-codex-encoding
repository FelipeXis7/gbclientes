    const s = estado.servicos.find(x => x.id === id);
    if (!s) return;
    s[campo] = campo === 'valor' ? Number(valor) : valor;
    salvarEstado();
}
function removerServico(id) {
    estado.servicos = estado.servicos.filter(s => s.id !== id);
    salvarEstado();
}

